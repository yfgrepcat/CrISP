acl "enterprise-nets" { 120.0.37.0/24; 10.12.30.0/24; 10.255.255.0/30; };
acl "crisp-nets" { 120.0.40.0/24; };
acl "residential-nets" { 120.0.38.0/24; };
acl "trusted" { enterprise-nets; residential-nets; };

options {
  directory "/var/cache/bind";
  listen-on port 53 { any; };
  listen-on-v6 { none; };
  recursion yes;
  allow-recursion { trusted; };
  allow-query { any; };
  dnssec-validation no;
  forwarders {
    120.0.48.34;
  };
  forward first;
};
